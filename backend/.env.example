# Copy this file to .env and adjust as needed.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/english_master

# Grammar checker. Defaults to the free public LanguageTool API (no setup
# needed). To self-host later: run LanguageTool (e.g. via Docker:
#   docker run -p 8010:8010 erikvl87/languagetool
# ) and point this at it instead:
# LANGUAGETOOL_URL=http://localhost:8010/v2/check
LANGUAGETOOL_URL=https://api.languagetool.org/v2/check

# Comma-separated list of allowed frontend origins for CORS. Leave as "*"
# for local development. Once deployed, set this to your real Netlify URL,
# e.g. https://english-master.netlify.app
ALLOWED_ORIGINS=*

# Admin dashboard (/admin) - lists every registered user and their practice
# activity. Protected by HTTP Basic Auth (the browser will prompt for these).
# Leave ADMIN_PASSWORD unset to disable /admin entirely (it returns 503).
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=choose-a-real-password-here
